        };

        const determineDifficulty = (roll, possibleDifficulties) => {
            const tierCount = possibleDifficulties.length; if (tierCount === 1) return possibleDifficulties[0];
            const sliceSize = 100 / tierCount; const index = Math.floor((roll - 1) / sliceSize);
            return possibleDifficulties[index < tierCount ? index : tierCount - 1];
        };

