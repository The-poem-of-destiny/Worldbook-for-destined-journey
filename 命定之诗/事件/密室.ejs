        banner: fmtBanner(curRoom),
        device: fmtDevice(curRoom)
      },
      已知房间列表: metRooms.map((room) => ({
        name: ROOM_INFO[room].name,
        summary: ROOM_INFO[room].summary,
        banner: fmtBanner(room)
      }))
    };

    if (curRoom === 0) {
      displayOutput.当前房间.item = FINAL_REWARD;
